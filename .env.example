# Copy this file to .env and fill in real values.
# NEVER commit the real .env file to git or include it in a zip you share/deploy from.

# Use a strong, unique database password - generate one, don't reuse an old one.
DATABASE_URL=postgresql://postgres:postgres245@localhost:5432/CyberInspect

# Generate with: openssl rand -hex 32
# The app will refuse to start if this is missing, too short, or left as a placeholder.
JWT_SECRET=292f88a113bd5fd3e59af9de3eb8d3a208c7d88ac47cbd1d07ad587176810d5dx

# "development" or "production"
ENVIRONMENT=production

# Only set to True in local development. Creates a known admin/demo login
# (admin@cyberinspect.io / admin123) - the app will refuse to start if this
# is True while ENVIRONMENT=production.
SEED_DEFAULT_USERS=False